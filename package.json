{
  "name": "pi-web-suite",
  "version": "0.2.0",
  "description": "Web search, URL fetching, PDF extraction, and content extraction tools for the Pi coding agent. Cascading providers: Exa, AnySearch, Tavily.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-web-suite",
    "web-search",
    "fetch",
    "extract"
  ],
  "license": "MIT",
  "type": "module",
  "main": "index.ts",
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "image": "https://github.com/Eddie0521/pi-web-suite/raw/main/screenshot.png"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "linkedom": "^0.16.0",
    "turndown": "^7.2.0",
    "unpdf": "^1.6.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Eddie0521/pi-web-suite.git"
  },
  "homepage": "https://github.com/Eddie0521/pi-web-suite#readme",
